<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="workable_employee.WorkableListView" t-inherit="web.ListView" t-inherit-mode="primary">
        <xpath expr="//t[@t-set-slot='control-panel-always-buttons']" position="replace">
            <t t-set-slot="control-panel-always-buttons">
                <button class="btn btn-primary" t-on-click="onSyncFromWorkable">
                    <i class="fa fa-refresh me-1"/> Sync Employees
                </button>
            </t>
        </xpath>
    </t>
</templates>